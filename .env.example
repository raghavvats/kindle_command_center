# ============================================================
# Kindle Command Center - environment / secrets
# Copy this file to ".env" and fill in the values you have.
# Every integration falls back to MOCK DATA when its keys are
# missing, so the dashboard runs fine before anything is set up.
# ============================================================

# --- Server ---
# Host/port the backend binds to. 0.0.0.0 makes it reachable
# from the Kindle on your local network.
HOST=0.0.0.0
PORT=8000

# ------------------------------------------------------------
# Todoist  (https://todoist.com/app/settings/integrations/developer)
# Personal API token. Read/write tasks.
# ------------------------------------------------------------
TODOIST_API_TOKEN=
# Optional Todoist filter (default: tasks due today & overdue)
TODOIST_FILTER=today | overdue

# ------------------------------------------------------------
# Calendar  (ICS / iCal feed)
# Notion Calendar and Google Calendar both expose a secret
# private .ics URL. Paste it here - no OAuth needed.
#   Google Calendar -> Settings -> "Secret address in iCal format"
# ------------------------------------------------------------
CALENDAR_ICS_URL=
# How many days ahead to show (default 3)
CALENDAR_DAYS_AHEAD=3

# ------------------------------------------------------------
# Spotify  (https://developer.spotify.com/dashboard)
# Create an app, then run: python scripts/spotify_auth.py
# to obtain the refresh token.
# Redirect URI must be added to the app settings exactly.
# ------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# ------------------------------------------------------------
# Weather  (Open-Meteo - NO API KEY REQUIRED)
# Just set your latitude/longitude. Defaults work out of the box.
# ------------------------------------------------------------
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
WEATHER_LABEL=New York
# "fahrenheit" or "celsius"
WEATHER_UNITS=fahrenheit

# ------------------------------------------------------------
# Hue / Home Assistant  (placeholder for now)
# Later, point this at Home Assistant to control Hue lights.
# ------------------------------------------------------------
HASS_URL=
HASS_TOKEN=
